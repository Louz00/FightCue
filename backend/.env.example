PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fightcue
FIGHTCUE_REQUIRE_DATABASE=true
FIGHTCUE_ALLOW_FILE_STATE_FALLBACK=false
FIGHTCUE_REQUIRE_SIGNED_DEVICE_TOKEN=false
REDIS_URL=redis://localhost:6379
APP_ID=com.lou.fightcue
FIGHTCUE_PUSH_PROVIDER=log
FIGHTCUE_FIREBASE_PROJECT_ID=
FIGHTCUE_FIREBASE_SERVICE_ACCOUNT_JSON=
FIGHTCUE_PUSH_WORKER_ENABLED=false
FIGHTCUE_PUSH_WORKER_INTERVAL_SECONDS=60
FIGHTCUE_PUSH_WORKER_LOOKBACK_MINUTES=15
# Alternatively use GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
