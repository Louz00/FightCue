{
  "name": "fightcue-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "db:start-local": "./scripts/start-local-postgres.sh",
    "db:stop-local": "./scripts/stop-local-postgres.sh",
    "db:verify-required": "./scripts/verify-required-postgres.sh",
    "migrate": "tsx src/db/migrate.ts",
    "test": "tsx --test $(find tests -name '*.test.ts' -print)"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "firebase-admin": "^13.7.0",
    "pg": "^8.16.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.39.1",
    "pg-mem": "^3.0.14",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
