{
  "name": "fightcue-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo \"eslint not configured yet\"",
    "db:start-local": "./scripts/start-local-postgres.sh",
    "db:stop-local": "./scripts/stop-local-postgres.sh",
    "migrate": "tsx src/db/migrate.ts",
    "test": "tsx --test $(find tests -name '*.test.ts' -print)"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "pg-mem": "^3.0.14",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
